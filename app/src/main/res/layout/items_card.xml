<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"

    >

    <LinearLayout
        android:id="@+id/containerLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="25dp"
        android:background="?android:attr/selectableItemBackground"
        android:elevation="8dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="1.0">

        <!-- CardView for elevated card with shadow -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            app:cardCornerRadius="8dp"
            app:cardMaxElevation="80dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                >


                <!-- ImageView for Image -->
                <ImageView
                    android:id="@+id/imageView_moharBook"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:scaleType="centerInside"

                    android:src="@drawable/tpps_logo"

                    android:visibility="visible" />

                <!-- TextView for Content -->
                <TextView
                    android:id="@+id/textContent_moharBook"
                    android:layout_width="match_parent"
                    android:textColor="@color/black"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5dp"
                    android:layout_marginTop="16dp"
                    android:text="Content"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:visibility="visible" />

                <!-- Other views as per your card layout -->
                <TextView
                    android:id="@+id/textOrderDate_moharBook"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:layout_marginLeft="5dp"
                    android:layout_marginTop="8dp"
                    android:text="Order Date: 01/01/2024"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/textMobileNo_moharBook"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:layout_marginLeft="5dp"
                    android:layout_marginTop="8dp"
                    android:text="Mobile No: 9823853678"
                    android:textSize="14sp" />

                <!-- LinearLayout for Total and Paid Amounts -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <!-- TextView for Total Amount -->
                    <TextView
                        android:id="@+id/textTotalAmount_moharBook"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:textColor="@color/black"
                        android:layout_marginLeft="5dp"
                        android:layout_weight="1"
                        android:text="Total: $100.00"
                        android:textSize="14sp" />

                    <!-- TextView for Paid Amount -->
                    <TextView
                        android:id="@+id/textPaidAmount_moharBook"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:textColor="@color/black"
                        android:layout_weight="1"
                        android:text="Paid: $50.00"
                        android:textSize="14sp" />

                    <!-- TextView for Due Amount -->
                    <TextView
                        android:id="@+id/textDueAmount_moharBook"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:textColor="@color/black"
                        android:layout_weight="1"
                        android:text="Due: $50.00"
                        android:textSize="14sp" />
                </LinearLayout>

                <Button
                    android:id="@+id/button_Whatsapp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginLeft="16dp"
                    android:layout_marginRight="16dp"
                    android:backgroundTint="#128c7e"
                    android:text="Whatsapp"
                    android:textColor="@android:color/white" />



                <!-- Button for Stage -->
                <Button
                    android:id="@+id/btnStage_moharBook"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginLeft="16dp"
                    android:layout_marginRight="16dp"
                    android:layout_marginBottom="16dp"
                    android:backgroundTint="@color/black"
                    android:text="Start"
                    android:textColor="@android:color/white" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
